{
  "_TUTORIAL_HOW_TO_USE": {
    "1. HOW TO ADD NEW CREDENTIALS": "Just copy an existing block (like 'National ID'), paste it at the bottom, change its name, color, and fields.",
    "2. LAYOUT TYPES": "Choose 'standard' (horizontal ID), 'vertical' (portrait badge), or 'bank' (credit card style with smart chip & no photo).",
    "3. FIELD MODES": "Set mode to 'user' for a blank typing box. Set mode to 'auto' for a locked box that auto-generates fake data.",
    "4. HOW MOCK TYPES WORK": "When mode is 'auto', you MUST provide a 'mockType' from the list below so the engine knows what kind of fake data to spit out."
  },

  "_SYSTEM_UPGRADES": {
    "newLayouts": ["passport", "secure", "minimal"],
    "newFieldTypes": ["biometric", "qr", "signature", "authority"],
    "note": "Use 'secure' for high-level IDs like passport, 'passport' for travel docs"
  },

  "_AVAILABLE_MOCK_TYPES": {
    "date": "Random date",
    "blood": "Blood group",
    "gender": "Gender",
    "vehicle": "Vehicle class",
    "tier": "Status tier",
    "network": "Crypto network",
    "score": "Rating score",
    "money": "Currency value",
    "area": "Property size",
    "cc": "Engine CC",
    "pan": "Indian PAN format",
    "card": "16-digit card",
    "cvv": "3-digit code",
    "plate": "Vehicle plate",
    "hash": "Secure hash",
    "id": "Alphanumeric ID",
    "passport": "Passport number (A1234567)",
    "visa": "Visa code",
    "nation": "Country name",
    "airport": "Airport code (DEL, JFK)",
    "flight": "Flight number (AI203)",
    "seat": "Seat (12A)",
    "pnr": "Booking PNR",
    "biometric": "Fingerprint/Face ID hash",
    "ip": "IP address",
    "device": "Device ID",
    "university": "Random university name",
    "course": "Course name",
    "grade": "Grade (A+, B, etc.)"
  },

